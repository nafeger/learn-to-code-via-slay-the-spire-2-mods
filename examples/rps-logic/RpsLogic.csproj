<Project Sdk="Microsoft.NET.Sdk">

  <!-- A standalone console app that holds the framework-independent RPS logic
       from Lessons 5-7, so it can be compiled and run OUTSIDE Slay the Spire 2.
       ImplicitUsings + TargetFramework match the real mod's JacksMod.csproj. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
